{
  "$schema": "./harness.config.schema.json",
  "version": "1.0.0",
  "mifConformanceLevel": 3,
  "features": {
    "internalCitations": false,
    "sigintCorpusImport": false
  },
  "topics": [
    {
      "id": "example-topic",
      "title": "Example research topic",
      "namespace": "harness/example-topic",
      "status": "active"
    }
  ],
  "dimensions": [
    {
      "id": "technical",
      "description": "Technical feasibility, architecture, and implementation evidence."
    },
    {
      "id": "landscape",
      "description": "Comparable prior art, alternatives, and competing approaches."
    },
    {
      "id": "trajectory",
      "description": "Direction of travel: adoption, standards, and momentum signals."
    }
  ],
  "outputs": [
    {
      "channel": "report",
      "enabled": true
    },
    {
      "channel": "blog",
      "enabled": true,
      "mifExempt": true,
      "mifExemptReason": "Published blog prose is orthogonal to MIF: the citation-leak gate keeps it free of internal MIF identity, so the MIF source of truth lives in the report channel, not the post."
    },
    {
      "channel": "book",
      "enabled": true,
      "mifExempt": true,
      "mifExemptReason": "Published book prose is orthogonal to MIF for the same reason as blog; the report channel carries the L3 MIF source of truth."
    }
  ],
  "packs": [
    {
      "name": "github-discuss",
      "enabled": false,
      "source": "bundled"
    },
    {
      "name": "github-issues",
      "enabled": false,
      "source": "bundled"
    },
    {
      "name": "notebooklm",
      "enabled": false,
      "source": "bundled"
    },
    {
      "name": "pdf",
      "enabled": false,
      "source": "bundled"
    },
    {
      "name": "competitive-analysis",
      "enabled": false,
      "source": "bundled"
    },
    {
      "name": "customer-research",
      "enabled": false,
      "source": "bundled"
    },
    {
      "name": "financial-analysis",
      "enabled": false,
      "source": "bundled"
    },
    {
      "name": "market-sizing",
      "enabled": false,
      "source": "bundled"
    },
    {
      "name": "regulatory-review",
      "enabled": false,
      "source": "bundled"
    },
    {
      "name": "academic",
      "enabled": true,
      "source": "bundled"
    },
    {
      "name": "briefing",
      "enabled": true,
      "source": "bundled"
    },
    {
      "name": "engineering",
      "enabled": true,
      "source": "bundled"
    },
    {
      "name": "exec-summary",
      "enabled": true,
      "source": "bundled"
    },
    {
      "name": "trend-analysis",
      "enabled": true,
      "source": "bundled"
    },
    {
      "name": "trend-modeling",
      "enabled": false,
      "source": "bundled"
    }
  ],
  "ontologies": [
    {
      "id": "regenerative-agriculture",
      "enabled": false
    },
    {
      "id": "k12-educational-publishing",
      "enabled": false
    },
    {
      "id": "software-engineering",
      "enabled": false
    },
    {
      "id": "biology-research-lab",
      "enabled": false
    },
    {
      "id": "backstage",
      "enabled": false
    },
    {
      "id": "csi-5w1h",
      "enabled": false
    }
  ]
}
