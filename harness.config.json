{
  "$schema": "./harness.config.schema.json",
  "version": "0.6.0",
  "mifConformanceLevel": 3,
  "features": {
    "internalCitations": false
  },
  "voice": {
    "profile": "default",
    "rules": {
      "noAiPunctuation": true,
      "noContractions": false,
      "warnBuzzwords": true
    }
  },
  "topics": [
    {
      "id": "example-okf-mif-knowledge-spine",
      "title": "Example: OKF+MIF as a foundational research knowledge spine",
      "namespace": "harness/example-okf-mif-knowledge-spine",
      "status": "archived",
      "ontologies": [
        "data-engineering",
        "software-engineering",
        "scientific",
        "market-research",
        "trend-analysis"
      ]
    }
  ],
  "dimensions": [
    {
      "id": "technical",
      "description": "Technical feasibility, architecture, and implementation evidence."
    },
    {
      "id": "landscape",
      "description": "Comparable prior art, alternatives, and competing approaches."
    },
    {
      "id": "trajectory",
      "description": "Direction of travel: adoption, standards, and momentum signals."
    },
    {
      "id": "market",
      "description": "Market analysis for an OKF+MIF knowledge spine: demand drivers, buyer segments, competitive positioning, and sizing."
    }
  ],
  "outputs": [
    {
      "channel": "report",
      "enabled": true
    },
    {
      "channel": "blog",
      "enabled": true,
      "mifExempt": true,
      "mifExemptReason": "Published blog prose is a MIF Level-1 output — its frontmatter carries the post's own urn:mif:blog: concept identity — but is exempt from the L3 I/O conformance gate because its published FORMAT is orthogonal to the L3 report. The body carries no internal finding identity (citation-leak gate); the canonical L3 source of truth is the report channel."
    }
  ],
  "freshness": {
    "default_days": 180,
    "by_citation_type": {
      "specification": 730,
      "book": 1095,
      "paper": 730,
      "dataset": 365,
      "documentation": 365,
      "repository": 180,
      "tool": 180,
      "other": 180,
      "website": 90,
      "article": 90,
      "video": 90,
      "podcast": 90
    }
  },
  "site": {
