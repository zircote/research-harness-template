# Astro/Starlight docs site build artifacts (package.json at repo root)
node_modules/
dist/
.astro/

# Python bytecode (the markdown hooks are plain scripts; bytecode is build cruft)
__pycache__/
*.pyc

# Codegen virtualenv (dev/build-time only; generated models under lib/ are committed)
.venv-codegen/

# Transient finding-authoring scripts agents emit (normally written to a temp dir)
author-finding*.py

# Hook runtime state
.claude/hooks/markdown/state/

# Instance-local materialized config — NOT template-managed and NOT byte-identical
# across instances. Rebuilt by scripts/sync-packs.sh from harness.config.json packs[],
# plus any local overrides (e.g. skillOverrides). The native `enabledPlugins` map
# lives in settings.local.json (the runtime deep-merges it with settings.json), so it
# stays out of the template-managed, byte-identical .claude/settings.json.
.claude/enabled-packs.json
.claude/settings.local.json

# NOTE: .copier-answers.yml is intentionally NOT ignored — it records the template
# commit (the merge base `copier update` needs) and must be committed in instances.

# Local-only design/upstream-proposal drafts (not shipped in the template)
docs/proposals/mif-entity-type-subsumption.md
*.json.tmp
*.tw.json
*.tmpwrite.json
*.mg
*.staging
.*.json.staging
*.fix.json
*.vb.json
reports/**/.gate_stderr*
# ADR-0011 derived run-state: non-deterministic (per-run wall-clock) status sidecar
# and the transient pre-synthesis withhold sentinel. Both are written into reports/
# at run time; committing them would dirty the tree every run and block copier update.
# (concordance.json itself stays tracked — it is deterministic and on the allowlist.)
reports/concordance-status.json
reports/**/.synthesis-withheld
